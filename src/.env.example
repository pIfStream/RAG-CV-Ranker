# ── LLM (Ollama) ───────────────────────────────────
# Ollama locale (consigliato per on-premise)
OLLAMA_LOCAL_HOST=http://localhost:11434
# Ollama cloud (opzionale)
# OLLAMA_HOST=https://ollama.com
# OLLAMA_TOKEN=your_token_here

LLM_MODEL=gemma4:latest
EMBED_MODEL_NAME=nomic-embed-text

# ── Database PostgreSQL ──────────────────────────
DATABASE_URL=postgresql://myuser:mypassword@localhost:5432/cv_db

# ── Path storage (on-premise) ────────────────────
# Dove salvare i CV caricati
CV_STORAGE_DIR=cv_storage
# Dove salvare i CV di reference per ruolo
ROLE_REFS_DIR=role_references

# ── CORS (frontend) ─────────────────────────────
# URL del frontend separati da virgola
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Logging ─────────────────────────────────────
LOG_LEVEL=INFO
